# Copy to .env and fill in real values. Never commit .env.
PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed browser origins (the Next.js app).
# No trailing slash. This project's *.vercel.app deployments are allowed
# automatically (preview hashes change per deploy), so you don't need to
# list them here — add only custom domains / other hosts.
CLIENT_ORIGINS=http://localhost:3000,http://192.168.1.6:3000

# Email (Gmail SMTP). Use a Google "app password", not your login password.
# If left blank, OTP codes are logged to the console instead of emailed.
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM=WalletCare <you@gmail.com>
